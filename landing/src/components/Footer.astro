---
const links = [
  ['MIT license', 'https://github.com/sayam-1705/codexa/blob/main/LICENSE'],
  ['GitHub', 'https://github.com/sayam-1705/codexa'],
  ['npm package', 'https://www.npmjs.com/package/codexa-toolkit'],
  ['Docs', 'https://github.com/sayam-1705/codexa/blob/main/docs/README.md'],
];
---

<footer class="section foot">
  <div class="top">
    <p class="brand mono">CODEXA</p>
    <p class="summary">
      AI pre-commit guardian for teams that want cleaner commits, less legacy-noise blocking, and a terminal
      workflow that stays close to the code.
    </p>
  </div>

  <div class="links mono">
    {links.map(([label, href], index) => (
      <>
        <a href={href}>{label}</a>
        {index < links.length - 1 && <span aria-hidden="true">/</span>}
      </>
    ))}
  </div>

  <p class="meta mono">Built with Ink, ESLint, Ruff, optional Ollama suggestions, and release-based npm publishing.</p>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: grid;
    gap: 14px;
  }

  .top {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
  }

  .brand {
    margin: 0;
    color: var(--text-strong);
    letter-spacing: 0.16em;
  }

  .summary,
  .meta {
    margin: 0;
    color: var(--muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--muted-strong);
    font-size: 0.92rem;
  }

  .links a {
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .top {
      grid-template-columns: 1fr;
    }
  }
</style>
