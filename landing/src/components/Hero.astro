    line-height: 1.1;
  }

  .sub {
    max-width: 70ch;
    color: var(--muted);
  }

  .eyebrow {
    color: var(--green);
    letter-spacing: 0.08em;
    font-size: 0.86rem;
  }

  .install {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    gap: 10px;
  }

  .install code {
    font-size: 0.96rem;
  }

  .install button {
    border: 1px solid rgba(200, 208, 224, 0.2);
    border-radius: 8px;
    background: #15152a;
    color: var(--text);
    padding: 8px 10px;
    cursor: pointer;
  }

  .actions {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .btn {
    border: 1px solid rgba(200, 208, 224, 0.25);
    color: var(--text);
    text-decoration: none;
    border-radius: 10px;
    padding: 11px 14px;
  }

  .btn.primary {
    background: var(--green);
    color: #03150f;
    border-color: transparent;
