<section class="section hero">
  <p class="eyebrow mono">CODEXA v1.0.0</p>
  <h1>The pre-commit tool that has your back.</h1>
  <p class="sub">
    Blame-aware linting. One-keypress fixes. Learns your codebase. Never nags you about errors you did not write.
  </p>

  <div class="install card">
    <code id="installCmd">npm install -g codexa</code>
    <button type="button" id="copyInstall">Copy</button>
  </div>

  <div class="actions">
    <a class="btn primary" href="/docs">Get Started</a>
    <a class="btn" href="https://github.com/sayam-1705/codexa">View on GitHub</a>
  </div>
</section>

<script>
  const copyBtn = document.getElementById('copyInstall');
  const installCmd = document.getElementById('installCmd');
  if (copyBtn && installCmd && navigator.clipboard) {
    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(installCmd.textContent || 'npm install -g codexa');
      copyBtn.textContent = 'Copied';
      setTimeout(() => {
        copyBtn.textContent = 'Copy';
      }, 1200);
    });
  }
</script>

