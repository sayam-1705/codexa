<section class="section">
  <h2>Quick Start</h2>

  <div class="tabs card">
    <input type="radio" id="solo" name="tab" checked />
    <input type="radio" id="team" name="tab" />

    <div class="labels">
      <label for="solo">Solo</label>
      <label for="team">Team</label>
    </div>

    <div class="panel solo mono">
      <pre>npm install -g codexa
cd your-project
codexa init
git add . && git commit -m "first protected commit"</pre>
    </div>

    <div class="panel team mono">
      <pre>npm install -g codexa
codexa config init --team
git add codexa.config.json .codexaignore
git commit -m "add codexa team config"
codexa init</pre>
    </div>
  </div>

  <h2 class="social">Social Proof</h2>
  <div class="quotes">
    <article class="card quote">"Placeholder testimonial from team lead."</article>
    <article class="card quote">"Placeholder testimonial from contributor."</article>
    <article class="card quote">"Placeholder testimonial from OSS maintainer."</article>
  </div>
</section>

<style>
  .tabs {
    padding: 12px;
  }

  .tabs input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .labels {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }

  .labels label {
    border: 1px solid rgba(200, 208, 224, 0.25);
    border-radius: 999px;
    padding: 7px 11px;
    cursor: pointer;
  }

  .panel {
    display: none;
    border: 1px solid rgba(200, 208, 224, 0.2);
    border-radius: 10px;
    padding: 10px;
    background: #090916;
  }

  #solo:checked ~ .panel.solo,
  #team:checked ~ .panel.team {
    display: block;
  }

  #solo:checked ~ .labels label[for="solo"],
  #team:checked ~ .labels label[for="team"] {
    border-color: transparent;
    background: var(--green);
    color: #03150f;
    font-weight: 600;
  }

  pre {
    margin: 0;
    white-space: pre-wrap;
  }

  .social {
    margin-top: 28px;
  }

  .quotes {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(3, 1fr);
  }

  .quote {
    padding: 12px;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .quotes {
      grid-template-columns: 1fr;
    }
  }
</style>
