{
  "version": 2,
  "blameMode": "strict",
  "languages": ["auto"],
  "severity": {
    "block": ["CRITICAL"],
    "warn": ["MODERATE"],
    "log": ["MINOR"],
    "overrides": {
      "no-console": "MINOR",
      "complexity": "CRITICAL"
    }
  },
  "ignore": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "__pycache__",
    "*.min.js",
    "migrations/"
  ],
  "team": {
    "name": "Engineering",
    "enforceOnCI": true,
    "blockThreshold": 1,
    "requireModel": null,
    "allowForceCommit": true,
    "forceCommitRequiresReason": true
  },
  "ci": {
    "outputFormat": "json",
    "postPRComment": true,
    "failOn": "CRITICAL",
    "badge": true
  },
  "_codexaSchema": "2.0.0"
}
